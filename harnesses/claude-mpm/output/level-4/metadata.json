{
  "level": 4,
  "title": "Document Processing Pipeline",
  "agent": "claude-mpm",
  "model": "claude-sonnet-4-6",
  "language": "Python",
  "python_version": "3.12",
  "architecture": {
    "pattern": "Chain of Responsibility + Plugin Architecture",
    "stages": [
      "ExtractionStage",
      "NLPStage",
      "IndexingStage",
      "SentimentStage"
    ],
    "storage": "SQLite (documents + FTS5 search index)",
    "api": "FastAPI with Pydantic v2",
    "nlp": "Regex-based (no external ML model downloads)"
  },
  "key_design_decisions": [
    "Regex NLP to avoid spaCy/NLTK model downloads in CI",
    "SQLite FTS5 for zero-dependency full-text search",
    "Isolated stage error handling via ctx.errors dict",
    "DocumentContext dataclass for type-safe shared state",
    "Open/Closed principle: new stages without modifying existing code"
  ],
