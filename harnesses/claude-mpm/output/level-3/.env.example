# OpenWeatherMap API key (required for live weather data)
# Get a free key at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_api_key_here

# Database path (default: weather.db in current directory)
DATABASE_PATH=weather.db

# Check interval in seconds for background scheduler (default: 300 = 5 minutes)
CHECK_INTERVAL_SECONDS=300

# Set to "true" to use mock weather data instead of real API calls
WEATHER_MOCK_MODE=false

# Set to "true" to use in-memory SQLite (testing only)
TESTING=false
